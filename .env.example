# Spring
SPRING_PROFILES_ACTIVE=dev

# Database
# - profile `dev`: H2 인메모리(application-dev.yml). 아래 MySQL 변수는 로컬에서 dev URL을 MySQL로 바꿀 때만 사용.
# - profile `prod`: MySQL 필수(DB_HOST, DB_NAME, DB_USERNAME, DB_PASSWORD).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mng_dev
DB_USERNAME=root
DB_PASSWORD=root

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long
